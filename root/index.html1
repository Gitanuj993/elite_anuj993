    border-radius: 10px;
}

.flex {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
}

.flex div {
    flex: 1;
    min-width: 250px;
}

.badge {
    display: inline-block;
    background: #1f6feb;
    color: white;
    padding: 5px 10px;
    margin: 5px;
    border-radius: 20px;
    font-size: 12px;
}

a {
    color: #1f6feb;
    text-decoration: none;
}

button {
    background: #1f6feb;
    color: white;
    border: none;
    padding: 10px 15px;
    border-radius: 5px;
    cursor: pointer;
}

button:hover {
    background: #1f6feb;
}
</style>
</head>


